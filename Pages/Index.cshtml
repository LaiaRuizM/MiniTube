@page
@model MiniTube.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Videos</h1>
        <a href="/Upload" class="btn btn-primary">Upload Video</a>
    </div>

    @if (!Model.Videos.Any())
    {
        <div class="text-center py-5">
            <h4 class="text-muted">No videos yet</h4>
            <p class="text-muted">Upload your first video to get started.</p>
            <a href="/Upload" class="btn btn-outline-primary">Upload Video</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var video in Model.Videos)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 video-card">
                        <div class="card-body">
                            <h5 class="card-title">@video.Title</h5>
                            <span class="badge bg-secondary mb-2">@video.Category</span>
                            <p class="card-text text-muted small">
                                @if (!string.IsNullOrWhiteSpace(video.Description))
                                {
                                    @(video.Description.Length > 100 ? video.Description[..100] + "..." : video.Description)
                                }
                            </p>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <small class="text-muted">@video.UploadedAt.ToString("MMM dd, yyyy")</small>
                            <a href="/Watch?id=@video.Id" class="btn btn-sm btn-outline-primary">Watch</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
