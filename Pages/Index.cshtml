@page
@model MiniTube.Pages.IndexModel
@using System.Security.Claims
@inject MiniTube.Services.VideoService VideoService
@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Videos</h1>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a href="/Upload" class="btn btn-primary">Upload Video</a>
        }
    </div>

    <!-- Search and Filter -->
    <form method="get" class="row g-2 mb-4">
        <div class="col-md-6">
            <input type="text" name="Search" value="@Model.Search" class="form-control"
                   placeholder="Search by title or description..." />
        </div>
        <div class="col-md-3">
            <select name="Category" class="form-select">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary flex-grow-1">Search</button>
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Category))
            {
                <a href="/" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    @if (!Model.Videos.Any())
    {
        <div class="empty-state">
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Category))
            {
                <div class="empty-icon">&#128269;</div>
                <h4>No videos found</h4>
                <p>Try a different search term or category.</p>
                <a href="/" class="btn btn-outline-secondary">Clear Filters</a>
            }
            else
            {
                <div class="empty-icon">&#127909;</div>
                <h4>No videos yet</h4>
                <p>Be the first to upload something!</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Upload" class="btn btn-outline-primary">Upload Video</a>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-outline-primary">Sign in to Upload</a>
                }
            }
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var video in Model.Videos)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 video-card">
                        @{
                            var thumbSrc = !string.IsNullOrEmpty(video.ThumbnailFileName)
                                ? VideoService.GetBlobSasUrl($"thumbnails/{video.ThumbnailFileName}")
                                    ?? $"/videos/thumbnails/{video.ThumbnailFileName}"
                                : null;
                        }
                        @if (thumbSrc != null)
                        {
                            <img src="@thumbSrc" class="card-img-top" alt="@video.Title thumbnail"
                                 style="height: 160px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
                                 style="height: 160px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="white"
                                     viewBox="0 0 16 16">
                                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                    <path d="M6.271 5.055a.5.5 0 0 1 .52.038l3.5 2.5a.5.5 0 0 1 0 .814l-3.5 2.5A.5.5 0 0 1 6 10.5v-5a.5.5 0 0 1 .271-.445z"/>
                                </svg>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@video.Title</h5>
                            <span class="badge bg-secondary mb-2">@video.Category</span>
                            <p class="card-text text-muted small">
                                @if (!string.IsNullOrWhiteSpace(video.Description))
                                {
                                    @(video.Description.Length > 100 ? video.Description[..100] + "..." : video.Description)
                                }
                            </p>
                        </div>
                        <div class="card-footer d-flex flex-column gap-2">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <small class="text-muted">@video.UploadedAt.ToString("MMM dd, yyyy")</small>
                                @{
                                    var hasLikes = Model.LikeCounts.TryGetValue(video.Id, out var counts);
                                    var likes = hasLikes ? counts.Likes : 0;
                                    var dislikes = hasLikes ? counts.Dislikes : 0;
                                }
                                @if (likes > 0 || dislikes > 0)
                                {
                                    <small><span class="text-success">&#128077;@likes</span></small>
                                    <small><span class="text-danger">&#128078;@dislikes</span></small>
                                }
                                @if (video.ViewCount > 0)
                                {
                                    <small class="text-muted">&#128065; @video.ViewCount</small>
                                }
                            </div>
                            @{
                                var userEmail = User.FindFirstValue(System.Security.Claims.ClaimTypes.Email);
                                var canEdit = User.Identity?.IsAuthenticated == true &&
                                    (Model.IsAdmin || (video.OwnerEmail != null &&
                                     video.OwnerEmail.Equals(userEmail, StringComparison.OrdinalIgnoreCase)));
                            }
                            <div class="d-flex gap-2">
                                <a href="/Watch?id=@video.Id" class="btn btn-sm btn-outline-primary">Watch</a>
                                @if (canEdit)
                                {
                                    <a href="/Edit?id=@video.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <form method="post" asp-page-handler="Delete" style="display:inline">
                                        <input type="hidden" name="id" value="@video.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Delete this video?')">Delete</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="d-flex justify-content-center align-items-center gap-2 mt-4 mb-4">
            @if (Model.CurrentPage > 1)
            {
                <a href="?Search=@Model.Search&Category=@Model.Category&CurrentPage=@(Model.CurrentPage - 1)"
                   class="btn btn-sm btn-outline-secondary">&larr; Previous</a>
            }
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <a href="?Search=@Model.Search&Category=@Model.Category&CurrentPage=@p"
                   class="btn btn-sm @(p == Model.CurrentPage ? "btn-primary" : "btn-outline-secondary")">@p</a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a href="?Search=@Model.Search&Category=@Model.Category&CurrentPage=@(Model.CurrentPage + 1)"
                   class="btn btn-sm btn-outline-secondary">Next &rarr;</a>
            }
        </nav>
    }
</div>
