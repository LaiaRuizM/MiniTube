@page
@model MiniTube.Pages.ProfileModel
@inject MiniTube.Services.VideoService VideoService
@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-4">
    <!-- Profile Header -->
    <div class="card mb-4">
        <div class="card-body d-flex align-items-center gap-4">
            <!-- Avatar -->
            <div style="position: relative; flex-shrink: 0;">
                @if (Model.ProfilePictureUrl != null)
                {
                    <img src="@Model.ProfilePictureUrl" alt="Profile"
                         class="rounded-circle"
                         style="width:72px; height:72px; object-fit:cover; border: 2px solid rgba(168,85,247,0.4);" />
                }
                else
                {
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:72px; height:72px; font-size:1.6rem; border: 2px solid rgba(168,85,247,0.4);">
                        @Model.UserName[0].ToString().ToUpper()
                    </div>
                }
                <!-- Upload trigger -->
                <label for="pictureInput" title="Change photo"
                       style="position:absolute; bottom:0; right:0; background:rgba(168,85,247,0.85);
                              border-radius:50%; width:24px; height:24px; display:flex;
                              align-items:center; justify-content:center; cursor:pointer;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="white" viewBox="0 0 16 16">
                        <path d="M10.5 8.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/>
                        <path d="M2 4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1.172a2 2 0 0 1-1.414-.586l-.828-.828A2 2 0 0 0 9.172 2H6.828a2 2 0 0 0-1.414.586l-.828.828A2 2 0 0 1 3.172 4H2zm.5 2a.5.5 0 1 1 0-1 .5.5 0 0 1 0 1zm9 2.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0z"/>
                    </svg>
                </label>
            </div>

            <!-- Upload form (hidden, auto-submits on file pick) -->
            <form method="post" asp-page-handler="UploadPicture" enctype="multipart/form-data" id="pictureForm">
                <input id="pictureInput" type="file" name="PictureFile"
                       accept=".jpg,.jpeg,.png,.gif,.webp"
                       style="display:none"
                       onchange="document.getElementById('pictureForm').submit()" />
            </form>

            <div>
                <h3 class="mb-1">
                    @Model.UserName
                    @if (Model.IsAdmin)
                    {
                        <span class="badge bg-warning text-dark ms-2">Admin</span>
                    }
                </h3>
                <p class="text-muted mb-0">@Model.UserEmail</p>
                <small class="text-muted">@Model.TotalVideos video@(Model.TotalVideos != 1 ? "s" : "") uploaded</small>
            </div>
        </div>
    </div>

    <!-- My Videos -->
    <h4 class="mb-3">
        @if (Model.IsAdmin)
        {
            <span>All Videos</span>
        }
        else
        {
            <span>My Videos</span>
        }
    </h4>

    @if (!Model.MyVideos.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">&#127909;</div>
            <h5>You haven't uploaded any videos yet</h5>
            <a href="/Upload" class="btn btn-outline-primary mt-2">Upload Your First Video</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var video in Model.MyVideos)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        @{
                            var thumbSrc = !string.IsNullOrEmpty(video.ThumbnailFileName)
                                ? VideoService.GetBlobSasUrl($"thumbnails/{video.ThumbnailFileName}")
                                    ?? $"/videos/thumbnails/{video.ThumbnailFileName}"
                                : null;
                        }
                        @if (thumbSrc != null)
                        {
                            <img src="@thumbSrc" class="card-img-top" alt="@video.Title"
                                 style="height: 160px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
                                 style="height: 160px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="white"
                                     viewBox="0 0 16 16">
                                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                    <path d="M6.271 5.055a.5.5 0 0 1 .52.038l3.5 2.5a.5.5 0 0 1 0 .814l-3.5 2.5A.5.5 0 0 1 6 10.5v-5a.5.5 0 0 1 .271-.445z"/>
                                </svg>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@video.Title</h5>
                            <span class="badge bg-secondary mb-2">@video.Category</span>
                            @if (video.OwnerName != null)
                            {
                                <small class="text-muted d-block">by @video.OwnerName</small>
                            }
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <div class="d-flex flex-column gap-1">
                                <small class="text-muted">@video.UploadedAt.ToString("MMM dd, yyyy")</small>
                                <small class="text-muted">
                                    @{
                                        var hasLikes = Model.LikeCounts.TryGetValue(video.Id, out var lc);
                                        var commentCount = Model.CommentCounts.TryGetValue(video.Id, out var cc) ? cc : 0;
                                    }
                                    <span class="text-success me-2">&#128077; @(hasLikes ? lc.Likes : 0)</span>
                                    <span class="text-danger me-2">&#128078; @(hasLikes ? lc.Dislikes : 0)</span>
                                    <span>&#128172; @commentCount</span>
                                </small>
                            </div>
                            <div class="d-flex gap-2">
                                <a href="/Watch?id=@video.Id" class="btn btn-sm btn-outline-primary">Watch</a>
                                <a href="/Edit?id=@video.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form method="post" asp-page-handler="Delete" style="display:inline">
                                    <input type="hidden" name="id" value="@video.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete this video?')">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
