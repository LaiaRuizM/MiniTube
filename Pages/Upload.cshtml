@page
@model MiniTube.Pages.UploadModel
@{
    ViewData["Title"] = "Upload Video";
}

<div class="container mt-4">
    <h1>Upload Video</h1>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label asp-for="Form.Title" class="form-label">Title</label>
                    <input asp-for="Form.Title" class="form-control" placeholder="Enter video title" />
                    <span asp-validation-for="Form.Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Form.Description" class="form-label">Description</label>
                    <textarea asp-for="Form.Description" id="descriptionField" class="form-control" rows="3"
                              placeholder="Describe your video (optional)" maxlength="500"
                              oninput="updateDesc(this)"></textarea>
                    <div class="d-flex justify-content-between mt-1">
                        <span asp-validation-for="Form.Description" class="text-danger"></span>
                        <span id="charCounter" style="font-size:0.8rem; color:#a1a1aa;">0 / 500</span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Form.Category" class="form-label">Category</label>
                    <select asp-for="Form.Category" class="form-select">
                        <option value="">-- Select a category --</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                    <span asp-validation-for="Form.Category" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Form.VideoFile" class="form-label">Video File</label>
                    <input asp-for="Form.VideoFile" class="form-control" type="file" accept=".mp4,.webm,.mov" />
                    <div class="form-text">Accepted formats: .mp4, .webm, .mov &mdash; max ~25 MB on Azure</div>
                    <span asp-validation-for="Form.VideoFile" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Upload</button>
                <a href="/" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updateDesc(el) {
            const counter = document.getElementById('charCounter');
            const len = el.value.length;
            counter.textContent = len + ' / 500';
            counter.style.color = len >= 450 ? '#f43f5e' : '#a1a1aa';
            counter.style.fontWeight = len >= 450 ? '600' : 'normal';
        }
    </script>
}
