@page
@model MiniTube.Pages.WatchModel
@inject MiniTube.Services.IVideoService VideoService
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Video?.Title ?? "Watch";
}

<div class="container mt-4 mb-5 pb-4">
    @if (Model.Video != null)
    {
        <div class="row g-4">
            <!-- Main video section -->
            <div class="col-lg-8">
                <div class="video-wrapper mb-3">
                    <video controls autoplay class="w-100 rounded" style="max-height: 70vh; background: #000;">
                        <source src="@Model.VideoUrl" type="video/mp4" />
                        Your browser does not support the video tag.
                    </video>
                </div>

                <h2>@Model.Video.Title</h2>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="d-flex gap-3 text-muted">
                        <span class="badge bg-secondary">@Model.Video.Category</span>
                        <small>Uploaded @Model.Video.UploadedAt.ToString("MMMM dd, yyyy")</small>
                        <small>@FormatFileSize(Model.Video.FileSizeBytes)</small>
                        <small>&#128065; @Model.Video.ViewCount views</small>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form method="post" asp-page-handler="Like" style="display:inline">
                                <input type="hidden" name="id" value="@Model.Video.Id" />
                                <button type="submit"
                                        class="btn btn-sm @(Model.UserVote == true ? "btn-success" : "btn-outline-success")">
                                    &#128077; @Model.LikeCount
                                </button>
                            </form>
                            <form method="post" asp-page-handler="Dislike" style="display:inline">
                                <input type="hidden" name="id" value="@Model.Video.Id" />
                                <button type="submit"
                                        class="btn btn-sm @(Model.UserVote == false ? "btn-danger" : "btn-outline-danger")">
                                    &#128078; @Model.DislikeCount
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="btn btn-sm btn-outline-success disabled">&#128077; @Model.LikeCount</span>
                            <span class="btn btn-sm btn-outline-danger disabled">&#128078; @Model.DislikeCount</span>
                        }
                    </div>
                </div>

                @if (Model.CanEdit)
                {
                    <div class="d-flex gap-2 mb-3">
                        <a href="/Edit?id=@Model.Video.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form method="post" asp-page-handler="Delete" style="display:inline">
                            <input type="hidden" name="id" value="@Model.Video.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Delete this video?')">Delete</button>
                        </form>
                    </div>
                }

                @if (Model.Video.OwnerName != null)
                {
                    <small class="text-muted">Uploaded by @Model.Video.OwnerName</small>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Video.Description))
                {
                    <div class="card">
                        <div class="card-body">
                            <p class="mb-0">@Model.Video.Description</p>
                        </div>
                    </div>
                }

                <a href="/" class="btn btn-outline-secondary mt-3">Back to videos</a>

                <!-- Comments Section -->
                <div class="mt-4">
                    <h5>Comments (@Model.Comments.Count)</h5>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form method="post" asp-page-handler="Comment" class="mb-4">
                            <input type="hidden" name="id" value="@Model.Video.Id" />
                            <div class="mb-2">
                                <textarea name="NewComment" class="form-control" rows="2"
                                          placeholder="Add a comment..." maxlength="1000" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary">Post</button>
                        </form>
                    }
                    else
                    {
                        <p class="text-muted"><a href="/Account/Login">Sign in</a> to leave a comment.</p>
                    }

                    @if (Model.Comments.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var comment in Model.Comments)
                            {
                                <div class="d-flex gap-3">
                                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width:36px; height:36px; color:white; font-weight:600;">
                                        @comment.UserName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <strong style="font-size:0.9rem;">@comment.UserName</strong>
                                            <small class="text-muted">@comment.CreatedAt.ToString("MMM dd, yyyy")</small>
                                            @{
                                                var userEmail = User.FindFirstValue(System.Security.Claims.ClaimTypes.Email);
                                                var canDeleteComment = User.Identity?.IsAuthenticated == true &&
                                                    (User.HasClaim("IsAdmin", "true") ||
                                                     comment.UserEmail.Equals(userEmail, StringComparison.OrdinalIgnoreCase));
                                            }
                                            @if (canDeleteComment)
                                            {
                                                <form method="post" asp-page-handler="DeleteComment" style="display:inline">
                                                    <input type="hidden" name="commentId" value="@comment.Id" />
                                                    <input type="hidden" name="id" value="@Model.Video.Id" />
                                                    <button type="submit" class="btn btn-link btn-sm text-danger p-0"
                                                            style="font-size:0.8rem;"
                                                            onclick="return confirm('Delete comment?')">Delete</button>
                                                </form>
                                            }
                                        </div>
                                        <p class="mb-0" style="font-size:0.95rem;">@comment.Content</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state py-4">
                            <div class="empty-icon">&#128172;</div>
                            <p class="mb-0">No comments yet. Be the first!</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Other Videos Sidebar -->
            <div class="col-lg-4">
                <div>
                    <h5 class="mb-3">Related Videos</h5>

                    @if (Model.RelatedVideos.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var video in Model.RelatedVideos)
                            {
                                <a href="/Watch?id=@video.Id" class="card text-decoration-none text-reset hover-card">
                                    <div style="position: relative; aspect-ratio: 16/9; overflow: hidden;">
                                        @if (!string.IsNullOrEmpty(video.ThumbnailFileName))
                                        {
                                            var sidebarThumbSrc = VideoService.GetBlobSasUrl($"thumbnails/{video.ThumbnailFileName}")
                                                ?? $"/videos/thumbnails/{video.ThumbnailFileName}";
                                            <img src="@sidebarThumbSrc"
                                                 alt="@video.Title"
                                                 style="width: 100%; height: 100%; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-secondary d-flex align-items-center justify-content-center w-100 h-100">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="white" viewBox="0 0 16 16">
                                                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                                    <path d="M6.271 5.055a.5.5 0 0 1 .52.038l3.5 2.5a.5.5 0 0 1 0 .814l-3.5 2.5A.5.5 0 0 1 6 10.5v-5a.5.5 0 0 1 .271-.445z"/>
                                                </svg>
                                            </div>
                                        }
                                    </div>
                                    <div class="card-body p-2">
                                        <h6 class="card-title mb-1" style="font-size: 0.95rem; line-height: 1.3;">@video.Title</h6>
                                        <small class="text-muted d-block">@video.Category</small>
                                        <small class="text-muted">@video.UploadedAt.ToString("MMM dd")</small>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No related videos available</p>
                    }
                </div>
            </div>
        </div>
    }
</div>


@functions {
    string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F1} GB";
    }
}
